      }

      .cards {
        grid-template-columns: 1fr;
        gap: 16px;
      }

      .card {
        padding: 24px 20px;
      }

      .calculator-box {
        padding: 28px 20px;
      }

      .calculator-box .input-group {
        flex-direction: column;
      }

      .calculator-box input {
        width: 100%;
      }

      .contact-form {
        padding: 28px 20px;
      }

      .social-floating {
        right: 10px;
        gap: 10px;
      }

      .social-floating a {
        width: 40px;
        height: 40px;
        font-size: 1rem;
      }

      .social-floating a::after {
        display: none;
      }
    }

    @media (max-width: 480px) {
      .hero h2 {
        font-size: 1.8rem;
